// ── Block interaction ─────────────────────────────────────
// breakBlock(x, y, z, face)
L.SetGlobal("breakBlock", L.NewFunction(func(L *lua.LState) int {
if e.ctx == nil { return 0 }
State.mu.RLock()
rid := State.RuntimeID
pos := State.Position
State.mu.RUnlock()
bp := protocol.BlockPos{int32(L.CheckInt(1)), int32(L.CheckInt(2)), int32(L.CheckInt(3))}
face := int32(L.OptInt(4, 1))
_ = e.ctx.SendToServer(&packet.PlayerAction{EntityRuntimeID: rid, ActionType: protocol.PlayerActionStartBreak, BlockPosition: bp, BlockFace: face})
_ = e.ctx.SendToServer(&packet.InventoryTransaction{
TransactionData: &protocol.UseItemTransactionData{
ActionType:      protocol.UseItemActionBreakBlock,
BlockPosition:   bp,
BlockFace:       face,
BlockRuntimeID:  0,
Position:        pos,
ClickedPosition: mgl32.Vec3{0.5, 0.5, 0.5},
HeldItem:        State.HeldItem,
},
})
_ = e.ctx.SendToServer(&packet.PlayerAction{EntityRuntimeID: rid, ActionType: protocol.PlayerActionStopBreak, BlockPosition: bp, BlockFace: face})
return 0
}))

// placeBlock(x, y, z, face, runtimeID)
L.SetGlobal("placeBlock", L.NewFunction(func(L *lua.LState) int {
if e.ctx == nil { return 0 }
State.mu.RLock()
pos := State.Position
State.mu.RUnlock()
bp := protocol.BlockPos{int32(L.CheckInt(1)), int32(L.CheckInt(2)), int32(L.CheckInt(3))}
face := int32(L.OptInt(4, 1))
_ = e.ctx.SendToServer(&packet.InventoryTransaction{
TransactionData: &protocol.UseItemTransactionData{
ActionType:      protocol.UseItemActionClickBlock,
BlockPosition:   bp,
BlockFace:       face,
BlockRuntimeID:  uint32(L.OptInt(5, 0)),
Position:        pos,
ClickedPosition: mgl32.Vec3{0.5, 0.5, 0.5},
HeldItem:        State.HeldItem,
},
})
return 0
}))

// ── Look ──────────────────────────────────────────────────
// lookAt(x, y, z) - rotate to face a position
L.SetGlobal("lookAt", L.NewFunction(func(L *lua.LState) int {
if e.ctx == nil { return 0 }
State.mu.RLock()
px, py, pz := State.Position[0], State.Position[1], State.Position[2]
rid := State.RuntimeID
State.mu.RUnlock()
tx, ty, tz := float32(L.CheckNumber(1)), float32(L.CheckNumber(2)), float32(L.CheckNumber(3))
dx := float64(tx - px)
dy := float64(ty - (py + 1.62))
dz := float64(tz - pz)
dist := math.Sqrt(dx*dx + dz*dz)
yaw := float32(-math.Atan2(dx, dz) * 180 / math.Pi)
pitch := float32(-math.Atan2(dy, dist) * 180 / math.Pi)
State.mu.Lock()
State.Yaw = yaw
State.Pitch = pitch
State.mu.Unlock()
_ = e.ctx.SendToServer(&packet.MovePlayer{
EntityRuntimeID: rid,
Position:        mgl32.Vec3{px, py, pz},
Yaw:             yaw,
Pitch:           pitch,
HeadYaw:         yaw,
Mode:            packet.MoveModeNormal,
OnGround:        true,
})
return 0
}))

// ── Hotbar ────────────────────────────────────────────────
// selectSlot(slot) - switch held hotbar slot
L.SetGlobal("selectSlot", L.NewFunction(func(L *lua.LState) int {
if e.ctx == nil { return 0 }
slot := byte(L.CheckInt(1))
State.mu.RLock()
rid := State.RuntimeID
State.mu.RUnlock()
_ = e.ctx.SendToServer(&packet.MobEquipment{
EntityRuntimeID: rid,
NewItem:         State.Inventory[slot],
InventorySlot:   slot,
HotBarSlot:      slot,
})
State.mu.Lock()
State.HeldSlot = slot
State.mu.Unlock()
return 0
}))

// ── PlayerAction constants ────────────────────────────────
actions := L.NewTable()
L.SetField(actions, "START_BREAK",        lua.LNumber(protocol.PlayerActionStartBreak))
L.SetField(actions, "ABORT_BREAK",        lua.LNumber(protocol.PlayerActionAbortBreak))
L.SetField(actions, "STOP_BREAK",         lua.LNumber(protocol.PlayerActionStopBreak))
L.SetField(actions, "DROP_ITEM",          lua.LNumber(protocol.PlayerActionDropItem))
L.SetField(actions, "START_SLEEP",        lua.LNumber(protocol.PlayerActionStartSleeping))
L.SetField(actions, "STOP_SLEEP",         lua.LNumber(protocol.PlayerActionStopSleeping))
L.SetField(actions, "RESPAWN",            lua.LNumber(protocol.PlayerActionRespawn))
L.SetField(actions, "JUMP",               lua.LNumber(protocol.PlayerActionJump))
L.SetField(actions, "START_SPRINT",       lua.LNumber(protocol.PlayerActionStartSprint))
L.SetField(actions, "STOP_SPRINT",        lua.LNumber(protocol.PlayerActionStopSprint))
L.SetField(actions, "START_SNEAK",        lua.LNumber(protocol.PlayerActionStartSneak))
L.SetField(actions, "STOP_SNEAK",         lua.LNumber(protocol.PlayerActionStopSneak))
L.SetField(actions, "START_GLIDE",        lua.LNumber(protocol.PlayerActionStartGlide))
L.SetField(actions, "STOP_GLIDE",         lua.LNumber(protocol.PlayerActionStopGlide))
L.SetField(actions, "START_SWIM",         lua.LNumber(protocol.PlayerActionStartSwimming))
L.SetField(actions, "STOP_SWIM",          lua.LNumber(protocol.PlayerActionStopSwimming))
L.SetField(actions, "START_FLY",          lua.LNumber(protocol.PlayerActionStartFlying))
L.SetField(actions, "STOP_FLY",           lua.LNumber(protocol.PlayerActionStopFlying))
L.SetField(actions, "MISSED_SWING",       lua.LNumber(protocol.PlayerActionMissedSwing))
L.SetField(actions, "START_CRAWL",        lua.LNumber(protocol.PlayerActionStartCrawling))
L.SetField(actions, "STOP_CRAWL",         lua.LNumber(protocol.PlayerActionStopCrawling))
L.SetGlobal("ACTION", actions)
}

// ── ESP / World to Screen ─────────────────────────────────────────────────
// worldToScreen(wx, wy, wz, screenW, screenH, fov) -> sx, sy, visible
// Projects a world position to screen coordinates
func (e *LuaEngine) registerESPAPI(L *lua.LState) {
L.SetGlobal("worldToScreen", L.NewFunction(func(L *lua.LState) int {
wx := float64(L.CheckNumber(1))
wy := float64(L.CheckNumber(2))
wz := float64(L.CheckNumber(3))
screenW := float64(L.CheckNumber(4))
screenH := float64(L.CheckNumber(5))
fov := float64(L.OptNumber(6, 70))

State.mu.RLock()
px := float64(State.Position[0])
py := float64(State.Position[1]) + 1.62
pz := float64(State.Position[2])
yaw := float64(State.Yaw) * math.Pi / 180
pitch := float64(State.Pitch) * math.Pi / 180
State.mu.RUnlock()

// Translate to camera space
dx := wx - px
dy := wy - py
dz := wz - pz

// Rotate by yaw
rx := dx*math.Cos(-yaw) - dz*math.Sin(-yaw)
ry := dy
rz := dx*math.Sin(-yaw) + dz*math.Cos(-yaw)

// Rotate by pitch
fy := ry*math.Cos(-pitch) - rz*math.Sin(-pitch)
fz := ry*math.Sin(-pitch) + rz*math.Cos(-pitch)

// Behind camera
if fz <= 0 {
L.Push(lua.LNumber(0))
L.Push(lua.LNumber(0))
L.Push(lua.LFalse)
return 3
}

// Project to screen
fovRad := fov * math.Pi / 180
scale := (screenH / 2) / math.Tan(fovRad/2)
sx := (rx/fz)*scale + screenW/2
sy := (-fy/fz)*scale + screenH/2
_ = rx

visible := sx >= 0 && sx <= screenW && sy >= 0 && sy <= screenH
L.Push(lua.LNumber(sx))
L.Push(lua.LNumber(sy))
L.Push(lua.LBool(visible))
return 3
}))

// sendESPData(data) - print ESP JSON to stdout for overlay app
L.SetGlobal("sendESPData", L.NewFunction(func(L *lua.LState) int {
data := L.CheckString(1)
fmt.Println("[ESP]" + data)
return 0
}))
}
