// ── Combat ────────────────────────────────────────────────
// attackEntity(runtimeID)
L.SetGlobal("attackEntity", L.NewFunction(func(L *lua.LState) int {
if e.ctx == nil { return 0 }
targetID := uint64(L.CheckInt(1))
State.mu.RLock()
rid := State.RuntimeID
State.mu.RUnlock()
_ = e.ctx.SendToServer(&packet.InventoryTransaction{
TransactionData: &protocol.UseItemOnEntityTransactionData{
TargetEntityRuntimeID: targetID,
ActionType:            protocol.UseItemOnEntityActionAttack,
HotBarSlot:            int32(State.HeldSlot),
HeldItem:              State.HeldItem,
},
})
_ = e.ctx.SendToServer(&packet.Animate{
ActionType:      packet.AnimateActionSwingArm,
EntityRuntimeID: rid,
SwingSource:     packet.AnimateSwingSourceAttack,
})
return 0
}))

// swingArm()
L.SetGlobal("swingArm", L.NewFunction(func(L *lua.LState) int {
if e.ctx == nil { return 0 }
State.mu.RLock()
rid := State.RuntimeID
State.mu.RUnlock()
_ = e.ctx.SendToServer(&packet.Animate{
ActionType:      packet.AnimateActionSwingArm,
EntityRuntimeID: rid,
SwingSource:     packet.AnimateSwingSourceAttack,
})
return 0
}))

// interactEntity(runtimeID) - right click entity
L.SetGlobal("interactEntity", L.NewFunction(func(L *lua.LState) int {
if e.ctx == nil { return 0 }
targetID := uint64(L.CheckInt(1))
